<% content_for :title, @order.number %>

<main>
  <%= link_to "Back to orders", orders_path, class: "back-link" %>

  <h1><%= @order.number %></h1>

  <dl class="details">
    <dt>Customer</dt>
    <dd><%= @order.customer_name %> (<%= @order.customer_email %>)</dd>
    <dt>Status</dt>
    <dd><%= human_status(@order.status) %></dd>
    <dt>Shipping address</dt>
    <dd class="pre-line"><%= @order.shipping_address %></dd>
    <dt>Order total</dt>
    <dd><%= format_cents(@order.total_cents) %></dd>
    <dt>Submitted</dt>
    <dd><%= l(@order.submitted_at, format: :long) %></dd>
  </dl>

  <section class="section">
    <h2>Available actions</h2>
    <% if @order.available_statuses.any? %>
      <div class="actions">
        <% @order.available_statuses.each do |status| %>
          <%= button_to "Move to #{human_status(status)}", status_order_path(@order), method: :patch, params: { status: status } %>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state">No further actions available.</p>
    <% end %>
  </section>

  <section class="section">
    <h2>Line items</h2>
    <table class="line-items-table">
      <thead>
        <tr>
          <th scope="col">Product</th>
          <th scope="col">SKU</th>
          <th scope="col" class="numeric">Qty</th>
          <th scope="col" class="numeric">Unit price</th>
          <th scope="col" class="numeric">Total</th>
        </tr>
      </thead>
      <tbody>
        <% @line_items.each do |line_item| %>
          <tr>
            <td><%= line_item.product.name %></td>
            <td><%= line_item.product.sku %></td>
            <td class="numeric"><%= line_item.quantity %></td>
            <td class="numeric"><%= format_cents(line_item.unit_price_cents) %></td>
            <td class="numeric"><%= format_cents(line_item.total_cents) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>

  <% tracking_pending = (@order.status == "shipped" && @tracking_events.empty?) ||
                        (@order.status == "delivered" && @tracking_events.none? { |event| event.status == "delivered" }) %>

  <section
    class="section"
    data-controller="tracking-refresh"
    data-tracking-refresh-pending-value="<%= tracking_pending %>">
    <h2>Tracking timeline</h2>

    <% if @tracking_events.any? %>
      <ol class="timeline">
        <% @tracking_events.each do |event| %>
          <li>
            <strong><%= human_status(event.status) %></strong>
            <span><%= event.description %></span>
            <small>
              <%= event.carrier %> <%= event.tracking_number %> &middot; <%= l(event.occurred_at, format: :short) %>
            </small>
          </li>
        <% end %>
      </ol>
      <% if tracking_pending %>
        <p class="empty-state">Tracking sync is updating.</p>
      <% end %>
    <% elsif tracking_pending %>
      <p class="empty-state">Tracking sync is running.</p>
    <% else %>
      <p class="empty-state">Tracking starts after the order ships.</p>
    <% end %>
  </section>

  <section class="section">
    <h2>Audit history</h2>
    <% if @audit_entries.any? %>
      <ol>
        <% @audit_entries.each do |entry| %>
          <li>
            <%= l(entry.occurred_at, format: :short) %>:
            <%= entry.changed_attribute.humanize %> changed from <%= human_status(entry.from_value) %> to <%= human_status(entry.to_value) %>
            <% if entry.actor %>
              by <%= entry.actor.name %>
            <% end %>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="empty-state">No status changes yet.</p>
    <% end %>
  </section>
</main>
