<% content_for :title, "Orders" %>

<main>
  <div class="page-header">
    <h1>Orders</h1>
  </div>

  <%= form_with url: orders_path, method: :get, class: "filters" do %>
    <%= label_tag :status_filter, "Filter by status" %>
    <%= select_tag :status,
                   options_for_select([["All statuses", ""]] + @statuses.map { |status| [human_status(status), status] }, @selected_status),
                   id: :status_filter,
                   onchange: "this.form.requestSubmit()" %>
    <noscript><%= submit_tag "Filter" %></noscript>
  <% end %>

  <%= form_with url: bulk_status_orders_path, method: :patch do %>
    <%= hidden_field_tag :filter_status, @selected_status %>
    <%= hidden_field_tag :filter_page, @page %>

    <div class="bulk-actions">
      <%= label_tag :status, "Bulk action" %>
      <%= select_tag :status, options_for_select(Order::STATUSES.map { |status| [human_status(status), status] }) %>
      <%= submit_tag "Apply" %>
    </div>

    <table>
      <thead>
        <tr>
          <th scope="col">Select</th>
          <th scope="col">Order</th>
          <th scope="col">Customer</th>
          <th scope="col">Status</th>
          <th scope="col" class="numeric">Total</th>
          <th scope="col">Submitted</th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td><%= check_box_tag "order_ids[]", order.id, false, id: "order_ids_#{order.id}" %></td>
            <td><%= link_to order.number, order_path(order) %></td>
            <td><%= order.customer_name %></td>
            <td><%= human_status(order.status) %></td>
            <td class="numeric"><%= format_cents(order.total_cents) %></td>
            <td class="nowrap"><%= l(order.submitted_at, format: :long) %></td>
          </tr>
        <% end %>
        <% if @orders.empty? %>
          <tr>
            <td colspan="6" class="empty-state">No orders found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <% if @total_pages > 1 %>
    <% pagination_params = { status: @selected_status.presence }.compact %>

    <nav class="pagination" aria-label="Order pages">
      <% if @page > 1 %>
        <%= link_to "Previous", orders_path(pagination_params.merge(page: @page - 1)) %>
      <% end %>

      <span>Page <%= @page %> of <%= @total_pages %></span>

      <% if @page < @total_pages %>
        <%= link_to "Next", orders_path(pagination_params.merge(page: @page + 1)) %>
      <% end %>
    </nav>
  <% end %>
</main>
